<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBERGUARD" 
        Height="650" 
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117">

    <Grid>    
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR - Dark Grey -->
        <Border Grid.Column="0" Background="#161b22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area with Pink Accent -->
                <Border Grid.Row="0" Background="#1a1f3a" Padding="10,15" Margin="0,0,0,15" BorderBrush="#ff69b4" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Name="AsciiLogo" 
                                   Text="Loading..." 
                                   FontFamily="Consolas" 
                                   FontSize="8" 
                                   Foreground="#ff69b4"
                                   TextAlignment="Center"
                                   LineHeight="10"/>
                        <TextBlock Text="CYBERGUARD" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="#ff69b4"
                                   FontFamily="Segoe UI"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="Cybersecurity Awareness Assistant" 
                                   FontSize="11" 
                                   Foreground="#8b949e" 
                                   TextAlignment="Center"
                                   Margin="0,5,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable Quick Topics Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel Margin="15,0,15,20">
                        <TextBlock Text="Quick Topics" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#ff69b4"
                                   Margin="0,0,0,15"/>

                        <!-- Topic Buttons -->
                        <Button Content="🔐 Password Safety" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="password">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🎣 Phishing Scams" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="phishing">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🦠 Malware Protection" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="malware">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🌐 Safe Browsing" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="browsing">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="👥 Social Engineering" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="scam">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🔑 Two-Factor Authentication" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="password">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🛡️ Privacy Tips" 
                                Background="#21262d"
                                Foreground="#c9d1d9"
                                BorderBrush="#30363d"
                                BorderThickness="1"
                                Height="35"
                                Margin="0,4"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="QuickTopic_Click" 
                                Tag="privacy">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#21262d"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Height="1" Background="#21262d" Margin="0,20,0,15"/>

                        <!-- Save Chat History Button -->
                        <Button Content="💾 Save Chat History" 
                                Background="#161b22"
                                Foreground="#ff69b4"
                                BorderBrush="#ff69b4"
                                BorderThickness="2"
                                Height="35"
                                Margin="0,5"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="SaveChatHistory_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#161b22"/>
                                    <Setter Property="Foreground" Value="#ff69b4"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Help / Instructions Button - VISIBLE BELOW -->
                        <Button Content="❓ Help / Instructions" 
                                Background="#161b22"
                                Foreground="#ff69b4"
                                BorderBrush="#ff69b4"
                                BorderThickness="2"
                                Height="35"
                                Margin="0,5"
                                HorizontalContentAlignment="Left"
                                Padding="10,0"
                                FontSize="13"
                                Cursor="Hand"
                                Click="Help_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#161b22"/>
                                    <Setter Property="Foreground" Value="#ff69b4"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#ff69b4"/>
                                            <Setter Property="Foreground" Value="#0d1117"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer at Bottom -->
                <Border Grid.Row="2" Background="#161b22" Padding="15,12" Margin="0,15,0,0" BorderBrush="#21262d" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="CYBERGUARD" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#ff69b4" 
                                   TextAlignment="Center"/>
                        <TextBlock Text="Protecting You Online" 
                                   FontSize="11" 
                                   Foreground="#8b949e" 
                                   TextAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT CHAT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Header - CENTERED -->
            <Border Grid.Row="0" Background="#0d1117" Padding="15,12" BorderBrush="#21262d" BorderThickness="0,0,0,1">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="CYBERGUARD - Cybersecurity Awareness Assistant" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Foreground="#ff69b4"
                               FontFamily="Segoe UI"
                               TextAlignment="Center"/>
                    <TextBlock Text="🔒 Your Online Safety Companion" 
                               FontSize="12" 
                               Foreground="#8b949e"
                               Margin="0,5,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Chat Display Area -->
            <Border Grid.Row="1" Background="#0d1117" Padding="15">
                <ScrollViewer Name="ChatScrollViewer" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Name="ChatDisplay" 
                               TextWrapping="Wrap" 
                               Foreground="#c9d1d9" 
                               FontSize="13"
                               FontFamily="Segoe UI"/>
                </ScrollViewer>
            </Border>

            <!-- Input Area -->
            <Border Grid.Row="2" Background="#161b22" Padding="15" BorderBrush="#21262d" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="UserInput" 
                             Grid.Column="0" 
                             Height="40" 
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Background="#0d1117"
                             Foreground="#c9d1d9"
                             BorderBrush="#30363d"
                             BorderThickness="1"
                             KeyDown="UserInput_KeyDown"
                             ToolTip="Type your message here...">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Name="SendButton" 
                            Grid.Column="1" 
                            Width="80" 
                            Height="40" 
                            Margin="10,0,0,0"
                            Content="Send" 
                            Background="#ff69b4" 
                            Foreground="#0d1117" 
                            FontWeight="Bold"
                            FontSize="14"
                            Cursor="Hand"
                            Click="SendButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#ff69b4"/>
                                <Setter Property="Foreground" Value="#0d1117"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ff99cc"/>
                                        <Setter Property="Foreground" Value="#0d1117"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>